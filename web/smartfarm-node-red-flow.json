  {
    "id": "function-control-payload",
    "type": "function",
    "z": "flow-smartfarm",
    "name": "控制命令转 MQTT 字符串",
    "func": "const p = msg.payload;\nlet command = null;\nif (typeof p === 'object' && p !== null) {\n  if (p.pump === 1 || p.pump === 0 || p.pump === 'auto') {\n    command = { pump: p.pump };\n  }\n} else if (typeof p === 'string') {\n  const trimmed = p.trim();\n  if (trimmed === 'P1' || trimmed === 'P0' || trimmed === 'PA') {\n    msg.payload = trimmed;\n    msg.topic = 'smartfarm/control';\n    return msg;\n  }\n  try {\n    const parsed = JSON.parse(trimmed);\n    if (parsed && (parsed.pump === 1 || parsed.pump === 0 || parsed.pump === 'auto')) {\n      command = { pump: parsed.pump };\n    }\n  } catch (e) {\n    node.warn('控制命令不是有效 JSON：' + trimmed);\n  }\n}\nif (!command) {\n  node.warn('控制命令无效，已拦截：' + JSON.stringify(p));\n  return null;\n}\nmsg.payload = JSON.stringify(command);\nmsg.topic = 'smartfarm/control';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 450,
    "y": 540,
    "wires": [
      [
        "mqtt-out-control"
      ]
    ]
  },
