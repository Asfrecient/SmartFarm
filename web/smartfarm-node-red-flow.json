  {
    "id": "ui-template-history",
    "type": "ui_template",
    "z": "flow-smartfarm",
    "group": "ui-group-history",
    "name": "Recent 10 Records",
    "order": 1,
    "width": 12,
    "height": 5,
    "format": "<style>\n.smartfarm-table{width:100%;border-collapse:collapse;font-size:14px;}\n.smartfarm-table th,.smartfarm-table td{padding:8px 10px;border-bottom:1px solid #e5e7eb;text-align:center;}\n.smartfarm-table th{background:#f7fafc;color:#2d3748;font-weight:600;}\n.smartfarm-table tr:nth-child(even){background:#fbfdff;}\n.smartfarm-badge-ok{color:#1f7a3f;font-weight:600;}\n.smartfarm-badge-alert{color:#c53030;font-weight:600;}\n</style>\n<table class=\"smartfarm-table\">\n  <thead>\n    <tr><th>时间</th><th>温度(℃)</th><th>湿度(%)</th><th>土壤(%)</th><th>光照(lx)</th><th>降雨(%)</th><th>水泵</th><th>报警</th></tr>\n  </thead>\n  <tbody>\n    <tr ng-repeat=\"r in msg.payload\">\n      <td>{{r.time}}</td><td>{{r.temp}}</td><td>{{r.hum}}</td><td>{{r.soil}}</td><td>{{r.light}}</td><td>{{r.rain}}</td>\n      <td>{{r.pump ? '开启' : '关闭'}}</td>\n      <td ng-class=\"r.alarm ? 'smartfarm-badge-alert' : 'smartfarm-badge-ok'\">{{r.alarm ? '异常' : '正常'}}</td>\n    </tr>\n  </tbody>\n</table>",
