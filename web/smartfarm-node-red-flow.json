  {
    "id": "fn-prepare",
    "type": "function",
    "z": "flow-smartfarm",
    "name": "Prepare Metrics",
    "func": "const p = msg.payload || {};\nconst now = new Date();\nconst row = {\n  time: now.toLocaleTimeString(),\n  temp: Number(p.temp ?? 0),\n  hum: Number(p.hum ?? 0),\n  soil: Number(p.soil ?? 0),\n  light: Number(p.light ?? 0),\n  rain: Number(p.rain ?? 0),\n  pump: Number(p.pump ?? 0),\n  pumpManual: Number(p.pumpManual ?? 0),\n  alarm: Number(p.alarm ?? 0)\n};\nlet history = flow.get('smartfarm_history') || [];\nhistory.unshift(row);\nhistory = history.slice(0, 10);\nflow.set('smartfarm_history', history);\nconst make = (payload) => ({ payload });\nconst chartMessages = [\n  { topic: '温度', payload: row.temp },\n  { topic: '湿度', payload: row.hum },\n  { topic: '土壤湿度', payload: row.soil },\n  { topic: '光照强度', payload: row.light },\n  { topic: '降雨状态', payload: row.rain }\n];\nreturn [\n  make(row.temp),\n  make(row.hum),\n  make(row.soil),\n  make(row.light),\n  make(row.rain),\n  make(row.pump ? '水泵：开启' : '水泵：关闭'),\n  make(row.alarm ? '报警：异常' : '报警：正常'),\n  make('MQTT: ' + row.time),\n  chartMessages,\n  make(history),\n  make(row.pumpManual ? '当前模式：手动控制' : '当前模式：自动控制')\n];",
    "outputs": 11,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 560,
    "y": 160,
    "wires": [
      [
        "ui-gauge-temp"
      ],
      [
        "ui-gauge-hum"
      ],
      [
        "ui-gauge-soil"
      ],
      [
        "ui-gauge-light"
      ],
