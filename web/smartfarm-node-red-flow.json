    "type": "function",
    "z": "flow-smartfarm",
    "name": "控制提示",
    "func": "const p = msg.payload || {};\nlet text = '已发送控制命令';\nif (p.pump === 1) {\n  text = '已发送：手动开启水泵';\n} else if (p.pump === 0) {\n  text = '已发送：手动关闭水泵';\n} else if (p.pump === 'auto') {\n  text = '已发送：恢复自动控制';\n}\nmsg.payload = text;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
